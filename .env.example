# Public application origin used for metadata and redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase browser-safe configuration. Configure in Phase 2.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase and Postgres server-only configuration. Configure in Phase 2.
SUPABASE_SECRET_KEY=
DATABASE_URL=

# Google Drive and Picker configuration. Configure in Phases 2 and 3.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=

# Server-only key used to encrypt Drive credential envelopes. Configure in Phase 2.
DRIVE_TOKEN_ENCRYPTION_KEY=
