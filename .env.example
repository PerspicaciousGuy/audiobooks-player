# Public application origin used for metadata and redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Use "preview" for UI-only development or "supabase" for real sessions.
NEXT_PUBLIC_AUTH_MODE=preview

# Supabase browser-safe configuration. Configure in Phase 2.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local Supabase Google identity provider values used by supabase/config.toml.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Supabase and Postgres server-only configuration. Configure in Phase 2.
SUPABASE_SECRET_KEY=
DATABASE_URL=

# Google Drive and Picker configuration. Configure in Phases 2 and 3.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
NEXT_PUBLIC_GOOGLE_CLOUD_PROJECT_NUMBER=

# Use "disabled" until the separate server-side Drive grant is configured.
DRIVE_INTEGRATION_MODE=disabled

# Server-only base64-encoded 32-byte key used to encrypt Drive credentials.
# Generate with: openssl rand -base64 32
DRIVE_TOKEN_ENCRYPTION_KEY=
